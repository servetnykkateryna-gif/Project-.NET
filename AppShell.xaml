<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VelvetRelics.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VelvetRelics"
    xmlns:views="clr-namespace:VelvetRelics.Views"
    Title="VelvetRelics"
    Shell.FlyoutBehavior="Disabled">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage" />

    <TabBar Route="MainPage">
        <Tab Title="Каталог" Icon="{FontImage FontFamily=OpenSansRegular, Glyph='🛒', Size=24, Color={StaticResource Primary}}">
            <ShellContent ContentTemplate="{DataTemplate views:CatalogPage}" />
        </Tab>
        <Tab Title="Обране" Icon="{FontImage FontFamily=OpenSansRegular, Glyph='❤', Size=24, Color={StaticResource Primary}}">
            <ShellContent ContentTemplate="{DataTemplate views:FavoritesPage}" />
        </Tab>
    </TabBar>

</Shell>
