<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:VelvetRelics.ViewModels"
             x:Class="VelvetRelics.Views.ProductDetailsPage"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource OffBlack}"
             Shell.NavBarIsVisible="False"
             x:DataType="viewmodels:ProductDetailsViewModel">

    <Grid RowDefinitions="*, Auto">
        
        <!-- Головний контент екрану -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">
                
                <!-- Блок зображення та кнопка Назад -->
                <Grid HeightRequest="350">
                    <Image Source="{Binding Product.ImageUrl}"
                           Aspect="AspectFill"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill" />
                    
                    <!-- Тонкий градієнт знизу зображення для преміального переходу до темного фону -->
                    <BoxView VerticalOptions="End"
                             HeightRequest="80"
                             Color="{StaticResource OffBlack}"
                             Opacity="0.8" />
                    
                    <!-- Кнопка повернення назад у верхньому лівому кутку -->
                    <Border Stroke="{StaticResource Tertiary}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 20"
                            BackgroundColor="{StaticResource MidnightBlue}"
                            HeightRequest="40"
                            WidthRequest="40"
                            HorizontalOptions="Start"
                            VerticalOptions="Start"
                            Margin="20,50,0,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="←"
                               TextColor="{StaticResource Primary}"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                </Grid>

                <!-- Блок деталей (опис, категорія, рік) -->
                <VerticalStackLayout Padding="25,10,25,25" Spacing="15">
                    
                    <!-- Категорія (бейдж) -->
                    <HorizontalStackLayout>
                        <Border Stroke="{StaticResource Tertiary}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{StaticResource Secondary}"
                                Padding="12,4">
                            <Label Text="{Binding Product.Category}"
                                   TextColor="{StaticResource Primary}"
                                   FontAttributes="Bold"
                                   FontSize="11"
                                   CharacterSpacing="1" />
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Назва шедевра -->
                    <Label Text="{Binding Product.Name}"
                           TextColor="{StaticResource White}"
                           FontAttributes="Bold"
                           FontSize="24"
                           LineBreakMode="WordWrap" />

                    <!-- Епоха / Рік виготовлення -->
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="⏳" FontSize="14" VerticalOptions="Center" />
                        <Label Text="Епоха створення:"
                               TextColor="{StaticResource Gray400}"
                               FontSize="14"
                               VerticalOptions="Center" />
                        <Label Text="{Binding Product.Year}"
                               TextColor="{StaticResource Primary}"
                               FontAttributes="Bold"
                               FontSize="14"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Роздільна лінія -->
                    <BoxView HeightRequest="1"
                             Color="{StaticResource Tertiary}"
                             Margin="0,5" />

                    <!-- Історичний Опис -->
                    <Label Text="Історична довідка та опис"
                           TextColor="{StaticResource Tertiary}"
                           FontSize="15"
                           FontAttributes="Bold" />
                    
                    <Label Text="{Binding Product.Description}"
                           TextColor="{StaticResource Gray200}"
                           FontSize="14"
                           LineHeight="1.5" />

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Фіксована панель дій внизу (Ціна та Кнопки) -->
        <Border Grid.Row="1"
                Stroke="{StaticResource Tertiary}"
                StrokeThickness="1,0,1,0"
                BackgroundColor="{StaticResource MidnightBlue}"
                Padding="20,15"
                StrokeShape="RoundRectangle 16,16,0,0">
            <Grid ColumnDefinitions="*, 2*">
                
                <!-- Блок ціни -->
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                    <Label Text="ВАЖЛИВІСТЬ"
                           TextColor="{StaticResource Gray400}"
                           FontSize="10"
                           CharacterSpacing="1" />
                    <Label Text="{Binding Product.Price, StringFormat='${0:N0}'}"
                           TextColor="{StaticResource Primary}"
                           FontSize="20"
                           FontAttributes="Bold" />
                </VerticalStackLayout>

                <!-- Кнопки дій -->
                <HorizontalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="10">
                    
                    <!-- Кнопка Обрати (Улюблене) -->
                    <Button Text="❤"
                            FontAttributes="Bold"
                            FontSize="18"
                            WidthRequest="50"
                            HeightRequest="50"
                            CornerRadius="25"
                            Command="{Binding ToggleFavoriteCommand}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsFavorite}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                <Setter Property="TextColor" Value="{StaticResource PrimaryDarkText}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding IsFavorite}" Value="False">
                                <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
                                <Setter Property="TextColor" Value="{StaticResource Primary}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button Text="ПРИДБАТИ"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource PrimaryDarkText}"
                            FontAttributes="Bold"
                            FontSize="13"
                            WidthRequest="140"
                            HeightRequest="50"
                            CornerRadius="25"
                            Command="{Binding AddToCartCommand}" />
                </HorizontalStackLayout>
                
            </Grid>
        </Border>
        
        <!-- Індикатор завантаження під час отримання деталей -->
        <Grid Grid.RowSpan="2"
              BackgroundColor="{StaticResource OffBlack}"
              Opacity="0.8"
              IsVisible="{Binding IsBusy}"
              VerticalOptions="Fill"
              HorizontalOptions="Fill">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"
                               HeightRequest="50"
                               WidthRequest="50" />
        </Grid>
        
    </Grid>
</ContentPage>
