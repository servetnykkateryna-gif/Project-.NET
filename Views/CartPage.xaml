<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:VelvetRelics.ViewModels"
             xmlns:services="clr-namespace:VelvetRelics.Services"
             x:Class="VelvetRelics.Views.CartPage"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource OffBlack}"
             x:DataType="viewmodels:CartViewModel">

    <Grid RowDefinitions="Auto, *, Auto">
        
        <!-- Заголовок сторінки -->
        <VerticalStackLayout Grid.Row="0" Padding="20,15,20,15" Spacing="5" BackgroundColor="{StaticResource MidnightBlue}">
            <Label Text="КОШИК"
                   FontFamily="OpenSansSemibold"
                   FontSize="22"
                   CharacterSpacing="2"
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center" />
            <Label Text="Ваші обрані скарби"
                   FontSize="12"
                   TextColor="{StaticResource Tertiary}"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Список товарів у кошику -->
        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding LoadCartCommand}">
            
            <CollectionView ItemsSource="{Binding CartItems}"
                            Margin="15,10">
                
                <!-- Порожній стан -->
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="30" Spacing="15" IsVisible="{Binding IsEmpty}">
                        <Label Text="🛒" FontSize="48" TextColor="{StaticResource Tertiary}" HorizontalOptions="Center" />
                        <Label Text="Кошик порожній" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource White}" HorizontalOptions="Center"/>
                        <Label Text="Перейдіть до каталогу та оберіть щось унікальне" FontSize="14" TextColor="{StaticResource Gray200}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <!-- Макет елемента -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:CartItemDto">
                        <Border Stroke="{StaticResource Tertiary}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{StaticResource MidnightBlue}"
                                Margin="0,5,0,10"
                                Padding="10">

                            <Grid ColumnDefinitions="80, *, Auto" ColumnSpacing="15">
                                
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 8" StrokeThickness="0">
                                    <Image Source="{Binding Product.ImageUrl}"
                                           Aspect="AspectFill"
                                           HeightRequest="80"
                                           WidthRequest="80" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Product.Name}"
                                           TextColor="{StaticResource White}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />
                                    <HorizontalStackLayout Spacing="10" Margin="0,5,0,0">
                                        <Label Text="Кількість:" TextColor="{StaticResource Tertiary}" FontSize="12" VerticalOptions="Center" />
                                        <Button Text="-"
                                                WidthRequest="28"
                                                HeightRequest="28"
                                                CornerRadius="14"
                                                Padding="0"
                                                BackgroundColor="Transparent"
                                                StrokeColor="{StaticResource Primary}"
                                                StrokeThickness="1"
                                                TextColor="{StaticResource Primary}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                VerticalOptions="Center"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CartViewModel}}, Path=DecreaseQuantityCommand}"
                                                CommandParameter="{Binding .}" />
                                        <Label Text="{Binding Quantity}" TextColor="{StaticResource White}" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" WidthRequest="20" HorizontalTextAlignment="Center" />
                                        <Button Text="+"
                                                WidthRequest="28"
                                                HeightRequest="28"
                                                CornerRadius="14"
                                                Padding="0"
                                                BackgroundColor="Transparent"
                                                StrokeColor="{StaticResource Primary}"
                                                StrokeThickness="1"
                                                TextColor="{StaticResource Primary}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                VerticalOptions="Center"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CartViewModel}}, Path=IncreaseQuantityCommand}"
                                                CommandParameter="{Binding .}" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding TotalPrice, StringFormat='${0:N0}'}"
                                           TextColor="{StaticResource Primary}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           Margin="0,5,0,0"/>
                                </VerticalStackLayout>

                                <ImageButton Grid.Column="2"
                                             Source="{FontImage FontFamily=OpenSansRegular, Glyph='✖', Size=16, Color={StaticResource Gray400}}"
                                             Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CartViewModel}}, Path=RemoveFromCartCommand}"
                                             CommandParameter="{Binding .}"
                                             BackgroundColor="Transparent"
                                             VerticalOptions="Center"
                                             HeightRequest="40"
                                             WidthRequest="40" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Підвал: Загальна сума та кнопка Оформлення -->
        <Border Grid.Row="2"
                IsVisible="{Binding IsNotEmpty}"
                Stroke="{StaticResource Tertiary}"
                StrokeThickness="1,0,1,0"
                BackgroundColor="{StaticResource MidnightBlue}"
                Padding="20,15"
                StrokeShape="RoundRectangle 16,16,0,0">
            <Grid ColumnDefinitions="*, Auto">
                
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                    <Label Text="ЗАГАЛОМ"
                           TextColor="{StaticResource Gray400}"
                           FontSize="10"
                           CharacterSpacing="1" />
                    <Label Text="{Binding TotalPrice, StringFormat='${0:N0}'}"
                           TextColor="{StaticResource Primary}"
                           FontSize="22"
                           FontAttributes="Bold" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="ОФОРМИТИ"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource PrimaryDarkText}"
                        FontAttributes="Bold"
                        FontSize="13"
                        WidthRequest="140"
                        HeightRequest="50"
                        CornerRadius="25"
                        Command="{Binding CheckoutCommand}" />
                
            </Grid>
        </Border>
    </Grid>
</ContentPage>
