<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:VelvetRelics.ViewModels"
             xmlns:models="clr-namespace:VelvetRelics.Models"
             x:Class="VelvetRelics.Views.CatalogPage"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource OffBlack}"
             x:DataType="viewmodels:CatalogViewModel">

    <Grid RowDefinitions="Auto, Auto, Auto, *">

        <!-- 1. Преміальний Заголовок та Кнопка Пошуку -->
        <Grid Grid.Row="0" Padding="20,15,20,5" ColumnDefinitions="*, Auto">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="VELVET RELICS"
                       FontFamily="OpenSansSemibold"
                       FontSize="26"
                       CharacterSpacing="3"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Start" />
                <Label Text="Ексклюзивний антикваріат"
                       FontSize="12"
                       TextColor="{StaticResource Tertiary}"
                       HorizontalOptions="Start" />
            </VerticalStackLayout>
            
            <ImageButton Grid.Column="1"
                         Source="{FontImage FontFamily=OpenSansRegular, Glyph='🔍', Size=24, Color={StaticResource Primary}}"
                         Command="{Binding ToggleSearchCommand}"
                         BackgroundColor="Transparent"
                         VerticalOptions="Center"
                         HeightRequest="40"
                         WidthRequest="40" />
        </Grid>

        <!-- 1.5. Пошукова панель (прихована за замовчуванням) -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsSearchVisible}"
                Stroke="{StaticResource Tertiary}"
                StrokeThickness="1"
                BackgroundColor="{StaticResource MidnightBlue}"
                StrokeShape="RoundRectangle 12"
                Margin="20,0,20,10"
                Padding="10,0"
                HeightRequest="45">
            <Grid ColumnDefinitions="*, Auto">
                <SearchBar Grid.Column="0"
                           Placeholder="Пошук скарбів..."
                           Text="{Binding SearchText}"
                           SearchCommand="{Binding SearchCommand}"
                           TextColor="{StaticResource White}"
                           PlaceholderColor="{StaticResource Gray400}"
                           CancelButtonColor="{StaticResource Primary}"
                           BackgroundColor="Transparent" />
                
                <ImageButton Grid.Column="1"
                             Source="{FontImage FontFamily=OpenSansRegular, Glyph='✖', Size=18, Color={StaticResource Gray400}}"
                             Command="{Binding ClearSearchCommand}"
                             BackgroundColor="Transparent"
                             VerticalOptions="Center"
                             HeightRequest="30"
                             WidthRequest="30" />
            </Grid>
        </Border>

        <!-- 2. Горизонтальний вибір категорій з підсвіткою обраної -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Categories}"
                        HeightRequest="50"
                        Margin="0,10,0,10"
                        HorizontalScrollBarVisibility="Never">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:CategoryItemViewModel">
                    <Grid Padding="5,0">
                        <Border StrokeThickness="1"
                                StrokeShape="RoundRectangle 20"
                                Padding="15,8"
                                Margin="5,2">

                            <!-- Підсвітка фону залежно від IsSelected -->
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                    <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                    <Setter Property="BackgroundColor" Value="{StaticResource MidnightBlue}" />
                                    <Setter Property="Stroke" Value="{StaticResource Tertiary}" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CatalogViewModel}}, Path=SelectCategoryCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Label Text="{Binding Name}"
                                   FontAttributes="Bold"
                                   FontSize="13"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource PrimaryDarkText}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource White}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- 3. Сітка Товарів (2 колонки) + Loading Overlay -->
        <Grid Grid.Row="3" x:Name="CatalogContentGrid" Opacity="0" TranslationY="30">

            <RefreshView IsRefreshing="{Binding IsBusy}"
                         Command="{Binding LoadProductsCommand}">
                
                <CollectionView ItemsSource="{Binding Products}"
                                Margin="10,0"
                                RemainingItemsThreshold="2">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    
                    <!-- Порожній стан — прихований під час завантаження -->
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="30" Spacing="10"
                                             IsVisible="{Binding IsNotBusy}">
                            <Label Text="🔎" FontSize="48" TextColor="{StaticResource Tertiary}" HorizontalOptions="Center" />
                            <Label Text="Колекція порожня" FontSize="18" TextColor="{StaticResource Tertiary}" HorizontalOptions="Center"/>
                            <Label Text="Спробуйте обрати іншу категорію" FontSize="14" TextColor="{StaticResource Gray200}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Product">
                            <Grid Padding="0" Margin="0,5">
                                <Border Stroke="{StaticResource Tertiary}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{StaticResource MidnightBlue}"
                                        HeightRequest="240">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CatalogViewModel}}, Path=GoToDetailsCommand}"
                                                               CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid RowDefinitions="*, Auto">
                                        
                                        <!-- Зображення товару -->
                                        <Image Grid.Row="0"
                                               Source="{Binding ImageUrl}"
                                               Aspect="AspectFill"
                                               HeightRequest="150"
                                               WidthRequest="200" />
                                        
                                        <!-- Опис та ціна -->
                                        <VerticalStackLayout Grid.Row="1" Padding="10,8" Spacing="4">
                                            <Label Text="{Binding Name}"
                                                   TextColor="{StaticResource White}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   MaxLines="1"
                                                   LineBreakMode="TailTruncation" />
                                            
                                            <Grid ColumnDefinitions="*, Auto">
                                                <Label Grid.Column="0"
                                                       Text="{Binding Year}"
                                                       TextColor="{StaticResource Tertiary}"
                                                       FontSize="11"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding Price, StringFormat='${0:N0}'}"
                                                       TextColor="{StaticResource Primary}"
                                                       FontSize="13"
                                                       FontAttributes="Bold"
                                                       VerticalOptions="Center" />
                                            </Grid>
                                        </VerticalStackLayout>
                                        
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

            <!-- Loading Overlay: показується поверх сітки під час завантаження -->
            <Grid IsVisible="{Binding IsBusy}"
                  BackgroundColor="{StaticResource OffBlack}"
                  VerticalOptions="Fill"
                  HorizontalOptions="Fill">
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource Primary}"
                                       HeightRequest="48"
                                       WidthRequest="48" />
                    <Label Text="Завантаження колекції..."
                           TextColor="{StaticResource Tertiary}"
                           FontSize="13"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

    </Grid>
</ContentPage>
