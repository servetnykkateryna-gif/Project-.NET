<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:VelvetRelics.ViewModels"
             xmlns:models="clr-namespace:VelvetRelics.Models"
             x:Class="VelvetRelics.Views.FavoritesPage"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource OffBlack}"
             x:DataType="viewmodels:FavoritesViewModel">

    <Grid RowDefinitions="Auto, *">
        
        <!-- Заголовок сторінки -->
        <VerticalStackLayout Grid.Row="0" Padding="20,15,20,15" Spacing="5" BackgroundColor="{StaticResource MidnightBlue}">
            <Label Text="ОБРАНЕ"
                   FontFamily="OpenSansSemibold"
                   FontSize="22"
                   CharacterSpacing="2"
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center" />
            <Label Text="Ваша приватна колекція скарбів"
                   FontSize="12"
                   TextColor="{StaticResource Tertiary}"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Список улюблених товарів -->
        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding LoadFavoritesCommand}">
            
            <CollectionView ItemsSource="{Binding FavoriteProducts}"
                            Margin="15,10">
                
                <!-- Порожній стан, якщо улюблених товарів немає -->
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="30" Spacing="15" IsVisible="{Binding IsEmpty}">
                        <Label Text="❤" FontSize="48" TextColor="{StaticResource Tertiary}" HorizontalOptions="Center" />
                        <Label Text="Галерея порожня" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource White}" HorizontalOptions="Center"/>
                        <Label Text="Додавайте товари з каталогу, щоб вони з'явилися тут" FontSize="14" TextColor="{StaticResource Gray200}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <!-- Макет кожного елемента у списку -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Product">
                        <Border Stroke="{StaticResource Tertiary}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{StaticResource MidnightBlue}"
                                Margin="0,5,0,10"
                                Padding="10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:FavoritesViewModel}}, Path=GoToDetailsCommand}"
                                                       CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="100, *, Auto" ColumnSpacing="15">
                                
                                <!-- Зображення товару -->
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 8" StrokeThickness="0">
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"
                                           HeightRequest="100"
                                           WidthRequest="100" />
                                </Border>

                                <!-- Інформація про товар -->
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding Category}"
                                           TextColor="{StaticResource Tertiary}"
                                           FontSize="11"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding Name}"
                                           TextColor="{StaticResource White}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Price, StringFormat='${0:N0}'}"
                                           TextColor="{StaticResource Primary}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           Margin="0,5,0,0"/>
                                </VerticalStackLayout>

                                <!-- Кнопка видалення з обраного -->
                                <ImageButton Grid.Column="2"
                                             Source="{FontImage FontFamily=OpenSansRegular, Glyph='✖', Size=16, Color={StaticResource Gray400}}"
                                             Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:FavoritesViewModel}}, Path=RemoveFromFavoritesCommand}"
                                             CommandParameter="{Binding .}"
                                             BackgroundColor="Transparent"
                                             VerticalOptions="Center"
                                             HeightRequest="40"
                                             WidthRequest="40" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
