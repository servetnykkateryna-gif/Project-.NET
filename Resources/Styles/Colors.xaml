<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Vintage Antique Shop Theme Colors -->
    <Color x:Key="Primary">#D4AF37</Color> <!-- Gold -->
    <Color x:Key="PrimaryDark">#B8860B</Color> <!-- Dark Gold -->
    <Color x:Key="PrimaryDarkText">#1A1514</Color>
    <Color x:Key="Secondary">#B87333</Color> <!-- Copper/Rust -->
    <Color x:Key="SecondaryDarkText">#FDF5E6</Color>
    <Color x:Key="Tertiary">#C2A878</Color> <!-- Vintage Tan -->

    <Color x:Key="White">#FDF5E6</Color> <!-- Cream/Off-white for text in dark mode, bg in light mode -->
    <Color x:Key="Black">#110D0C</Color> <!-- Very dark for text in light mode -->
    <Color x:Key="Magenta">#8B0000</Color> <!-- Dark Red accent -->
    <Color x:Key="MidnightBlue">#2C2422</Color> <!-- Surface Dark Brown -->
    <Color x:Key="OffBlack">#1A1514</Color> <!-- Background Dark Brown -->

    <Color x:Key="Gray100">#E6D5C3</Color>
    <Color x:Key="Gray200">#D2B48C</Color>
    <Color x:Key="Gray300">#A88A68</Color>
    <Color x:Key="Gray400">#8C7053</Color>
    <Color x:Key="Gray500">#6E543C</Color>
    <Color x:Key="Gray600">#523D2A</Color>
    <Color x:Key="Gray900">#2C2422</Color>
    <Color x:Key="Gray950">#1A1514</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>